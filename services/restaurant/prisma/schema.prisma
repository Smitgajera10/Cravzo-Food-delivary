generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Restaurant {
  id          String                                @id @default(uuid())
  ownerId     String                                @unique
  name        String
  description String?
  image       String
  address     String
  latitude    Float?
  longitude   Float?
  isVerified  Boolean                               @default(false)
  isActive    Boolean                               @default(false)
  createdAt   DateTime                              @default(now())
  updatedAt   DateTime                              @updatedAt
  phone       BigInt
  location    Unsupported("geography(Point,4326)")?

  menus Menu[]
  cart  Cart[]

  @@index([ownerId])
  @@index([isActive])
  @@index([location], map: "restaurant_location_gix", type: Gist)
}

model Menu {
  id           String   @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Float
  isAvailable  Boolean  @default(true)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems  Cart[]

  @@index([restaurantId])
}

model Cart {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  itemId       String
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menu       Menu       @relation(fields: [itemId], references: [id])

  @@unique([userId, restaurantId, itemId])
  @@index([userId])
  @@index([itemId])
  @@index([restaurantId])
}

model Address {
  id               String                                @id @default(uuid())
  userId           String
  mobile           BigInt
  formattedAddress String
  latitude         Float
  longitude        Float
  location         Unsupported("geography(Point,4326)")?
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt

  @@index([userId])
  @@index([location], map: "Address_location_gix", type: Gist)
}
