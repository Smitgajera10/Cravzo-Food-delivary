generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Restaurant {
  id          String                                @id @default(uuid())
  ownerId     String                                @unique
  name        String
  description String?
  image       String
  address     String
  latitude    Float?
  longitude   Float?
  isVerified  Boolean                               @default(false)
  isActive    Boolean                               @default(false)
  createdAt   DateTime                              @default(now())
  updatedAt   DateTime                              @updatedAt
  phone       BigInt
  location    Unsupported("geography(Point,4326)")?

  menus Menu[]
  cart  Cart[]
  orders Order[]

  @@index([ownerId])
  @@index([isActive])
  @@index([location], map: "restaurant_location_gix", type: Gist)
}

model Menu {
  id           String   @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Float
  isAvailable  Boolean  @default(true)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems  Cart[]

  @@index([restaurantId])
}

model Cart {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  itemId       String
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menu       Menu       @relation(fields: [itemId], references: [id])

  @@unique([userId, restaurantId, itemId])
  @@index([userId])
  @@index([itemId])
  @@index([restaurantId])
}

model Address {
  id               String                                @id @default(uuid())
  userId           String
  mobile           BigInt
  formattedAddress String
  latitude         Float
  longitude        Float
  location         Unsupported("geography(Point,4326)")?
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt

  @@index([userId])
  @@index([location], map: "Address_location_gix", type: Gist)
}


enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY_FOR_RIDER
  RIDER_ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  RAZORPAY
  STRIPE
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model OrderItem {
  id       String  @id @default(uuid())

  orderId  String
  itemId   String
  name     String
  price    Float
  quantity Int

  order    Order   @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Order {
  id             String   @id @default(uuid())
  userId         String
  restaurantId   String
  restaurantName String

  riderId        String?
  riderPhone     BigInt?
  riderName      String?

  subTotal       Float
  deliveryFee    Float
  platformFee    Float
  riderAmount    Float      // payout for rider
  distance       Float      // delivery distance in KM
  totalAmount    Float

  addressId      String?

  deliveryAddress String
  deliveryMobile  BigInt
  deliveryLat     Float
  deliveryLng     Float

  status         OrderStatus   @default(PLACED)
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)

  expiresAt      DateTime? 

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          OrderItem[]

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
}